# GrafanaProbe v2 — Configuration
# Copy to .env and fill in your values: cp .env.example .env

# === Grafana Instance ===
GRAFANA_URL=http://localhost:3000
GRAFANA_API_TOKEN=glsa_your_service_account_token
GRAFANA_ORG_ID=1

# === Server ===
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# === Paths ===
SCREENSHOTS_DIR=./screenshots
REPORTS_DIR=./reports
DB_PATH=./data/grafana-probe.db

# === Thresholds ===
QUERY_TIMEOUT_MS=15000
DASHBOARD_LOAD_TIMEOUT_MS=30000
STALE_DATA_THRESHOLD_MS=900000
SLOW_QUERY_THRESHOLD_MS=5000

# === K6 (optional) ===
K6_BINARY=k6
K6_VUS=10
K6_DURATION=30s

# === Webhooks (optional) ===
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
CUSTOM_WEBHOOK_URL=

# === Plugin Update Check ===
GRAFANA_COM_API=https://grafana.com/api
PLUGIN_CHECK_RATE_LIMIT_MS=200
