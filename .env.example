# Grafana k6 UI Tester Configuration
# Copy this to .env and fill in your values:  cp .env.example .env
# .env is gitignored — your URL and token will NOT be committed

# === REQUIRED ===
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=

# === OPTIONAL ===
GRAFANA_ORG_ID=1
TEST_LEVEL=full              # smoke | standard | full
SCREENSHOT_ON_FAIL=true
HEADLESS=true
REPORT_DIR=./reports
BASELINE_REPORT=             # Path to previous JSON report for comparison
DASHBOARD_LOAD_TIMEOUT=30000
RATE_LIMIT_MS=500
MAX_RETRIES=3
