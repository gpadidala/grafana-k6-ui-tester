# Grafana k6 UI Tester Configuration
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=
GRAFANA_ORG_ID=1
TEST_LEVEL=full              # smoke | standard | full
SCREENSHOT_ON_FAIL=true
HEADLESS=true
PARALLEL_VUS=3
REPORT_DIR=./reports
BASELINE_REPORT=             # Path to previous JSON report for comparison
DASHBOARD_LOAD_TIMEOUT=10000
RATE_LIMIT_MS=500
MAX_RETRIES=3
